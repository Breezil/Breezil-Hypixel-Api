    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@breezil/hypixel-parsers": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.3.0",
    "vitepress": "^1.6.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "publishConfig": {
    "access": "public"
